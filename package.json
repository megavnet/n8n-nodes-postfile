{
  "name": "n8n-nodes-postfile",
  "version": "0.0.1",
  "description": "n8n community node for PostFile. Upload files and get public URLs instantly.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "file upload",
    "file hosting",
    "public url",
    "cdn"
  ],
  "license": "MIT",
  "homepage": "https://postfile.net",
  "author": {
    "name": "PostFile",
    "email": "support@postfile.net"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/megavnet/n8n-nodes-postfile.git"
  },
  "main": "index.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PostFileApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PostFile/PostFile.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && cp nodes/PostFile/postfile.svg dist/nodes/PostFile/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "n8n-workflow": "^2.13.1",
    "typescript": "~5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
